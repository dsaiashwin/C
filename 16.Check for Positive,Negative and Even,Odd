#include<stdio.h>
int main()
{
    int n;
    scanf("%d",&n);
    
    if (n == 0)
    {
        printf("The number is zero.");
    }
    else
    {
        if (n > 0)
        {
            if (n % 2 ==0)
            {
                printf("The number %d is positive and even.",n);
            }
            else
            {
                printf("The number %d is positive and odd.",n);
            }
        }
        else 
        {
            if (n % 2 ==0)
            {
                printf("The number %d is negative and even.",n);
            }
            else
            {
                printf("The number %d is negative and odd.",n);
            } 
        }
    }
}
