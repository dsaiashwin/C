#include<stdio.h>
int main()
{ int n,rev=0;
    //printf("Enter the numbr:\n");
    scanf("%d",&n);
    if (n>=0)
    {
        while (n>0)
        {   
            rev=(rev*10) + (n%10);
            n=n/10;
        }
        printf("Reversed number is %d",rev);
    }
    else
    {printf("Please enter a positive integer");}
    
}
