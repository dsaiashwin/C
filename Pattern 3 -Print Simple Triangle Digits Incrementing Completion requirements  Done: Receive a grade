#include <stdio.h>
int main()
{
    int num,i,j,v=0;
    scanf("%d",&num);
    
    for (i=0 ; i < (num+1) ; i++)
    {
        for (j=1 ; j <= i ; j++)
        {   v+=1;
            printf("%d ",v);
        }
        printf("\n");
    }
}
