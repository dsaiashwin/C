#include <stdio.h>
int main()
{
    char c;
    scanf("%c",&c);
    
    switch (c)
    {
        case 'N':
        printf("North");
        break;
        
        case 'n':
        printf("North");
        break;
        
        case 'E':
        printf("East");
        break;
        
        case 'e':
        printf("East");
        break;
        
        case 'W':
        printf("West");
        break;
        
        case 'w':
        printf("West");
        break;
        
        case 'S':
        printf("South");
        break;
        
        case 's':
        printf("South");
        break;
        
        default :
        printf("Invalid input");
        
    }
}
