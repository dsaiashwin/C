Enter max lines: 4

1
12
123
1234

Enter max lines: 5

1
12
123
1234
12345
*/
#include <stdio.h>
int main()
{
    int num,i,j;
    scanf("%d",&num);
    
    for (i=0; i < (num+1) ; i++)
    {
        for (j=1; j < (i+1) ; j++)
        {
            printf("%d ",j);
        }
        printf("\n");
    }
}
